{
  "name": "athome-front",
  "version": "0.1.0",
  "private": true,
  "prettier": {
    "plugins": [
      "@trivago/prettier-plugin-sort-imports",
      "prettier-plugin-tailwindcss"
    ],
    "importOrder": [
      "^(server-only|client-only)$",
      "<SEPARATOR>",
      "<BUILTIN_MODULES>",
      "<THIRD_PARTY_MODULES>",
      "<SEPARATOR>",
      "^@/(.*)$",
      "<SEPARATOR>",
      "^\\.\\./",
      "^\\./"
    ],
    "importOrderSeparation": true,
    "importOrderSortSpecifiers": true,
    "importOrderCaseInsensitive": true,
    "importOrderSideEffects": true
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "tsc --noEmit && eslint . --cache --fix",
    "sort-messages": "./scripts/sort-messages.py",
    "spellcheck": "cspell .",
    "format": "prettier . --write",
    "i18n": "i18n-check --locales messages --source en --unused src --format next-intl"
  },
  "dependencies": {
    "next": "16.2.9",
    "next-intl": "^4.13.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.7.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cspell/dict-uk-ua": "^4.0.6",
    "@lingual/i18n-check": "^0.9.5",
    "@tailwindcss/postcss": "^4",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cspell": "^10.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "allowScripts": {
    "@parcel/watcher@2.5.6": true,
    "@swc/core@1.15.43": true,
    "sharp@0.34.5": true,
    "unrs-resolver@1.12.2": true
  }
}
